# Root environment variables
# Copy this file to .env and fill in values

# Database
DATABASE_URL=postgresql://taskai:taskai@localhost:5432/taskai?schema=public

# JWT (must be 32+ characters each)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# AI Provider (currently only "bedrock" supported)
AI_PROVIDER=bedrock

# AWS / Bedrock
# Enable Bedrock model access in AWS Console > Bedrock > Model access for your region
# Uses IAM credentials from AWS CLI profile or env vars (AWS_ACCESS_KEY_ID, etc.)
AWS_REGION=us-east-1
BEDROCK_LLM_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_MAX_OUTPUT_TOKENS=1024

# Chat rate limiting
MAX_CHAT_REQUESTS_PER_MINUTE=10

# Semantic deduplication threshold (0-1, higher = stricter)
DEDUP_SIMILARITY_THRESHOLD=0.92

# Rate limiting (general API)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Node
NODE_ENV=development
