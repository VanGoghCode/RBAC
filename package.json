{
  "name": "rbac",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "nx serve web",
    "dev:web": "nx serve web",
    "dev:api": "nx serve api",
    "dev:db": "docker compose up -d postgres",
    "dev:db:down": "docker compose down",
    "dev:db:reset": "docker compose down -v && docker compose up -d postgres",
    "db:init": "node -e \"const pg=require('pg');const c=new pg.Client(process.env.DATABASE_URL||'postgresql://taskai:taskai@localhost:5432/taskai');c.connect().then(()=>c.query('CREATE EXTENSION IF NOT EXISTS vector').then(()=>{console.log('pgvector ready');c.end()}))\"",
    "build": "nx run-many -t build --all",
    "build:web": "nx build web",
    "build:api": "nx build api",
    "test": "nx run-many -t test --all",
    "test:web": "nx test web",
    "test:api": "nx test api",
    "pretest": "pnpm run db:generate",
    "pretypecheck": "pnpm run db:generate",
    "lint": "nx run-many -t lint --all",
    "lint:web": "nx lint web",
    "lint:api": "nx lint api",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b apps/web/tsconfig.app.json apps/api/tsconfig.app.json libs/shared/types/tsconfig.lib.json libs/shared/validation/tsconfig.lib.json libs/shared/config/tsconfig.lib.json libs/shared/test-utils/tsconfig.lib.json --pretty false",
    "prepare": "husky",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset --force",
    "db:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:push": "prisma db push"
  },
  "private": true,
  "devDependencies": {
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
